{
  "manifest_version": 3,
  "name": "PDF Watermark",
  "version": "0.1.0",
  "description": "Add text watermarks to PDFs locally in your browser. Files never leave your machine.",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "PDF Watermark",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  },
  "permissions": []
}
